{
  "syntax": {
    "paths": [
      "src",
      "app",
      "config",
      "database",
      "tests",
      "benchmarks",
      "examples"
    ]
  },
  "duplicates": {
    "paths": [
      "src",
      "app",
      "config",
      "database"
